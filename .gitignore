# ── AEM SDK binaries — place in this folder but never commit ─────────────────
aem-sdk-*.zip
sdk-extracted/

# ── Quickstart JARs (copied from SDK by aem-setup.sh) ────────────────────────
author/aem-sdk-quickstart-*.jar
publish/aem-sdk-quickstart-*.jar

# ── AEM repository data (generated on first boot, can be GBs in size) ────────
author/crx-quickstart/
publish/crx-quickstart/

# ── Dispatcher extracted tools (regenerated by aem-setup.sh) ─────────────────
# The entire dispatcher/dispatcher-sdk-*/ folder is generated — never commit it
dispatcher/dispatcher-sdk-*/
dispatcher/bin/
dispatcher/lib/
dispatcher/docker_run.sh
dispatcher/README

# ── Environment file (contains credentials) ──────────────────────────────────
.env

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr